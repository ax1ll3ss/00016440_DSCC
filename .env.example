# Django
DJANGO_SECRET_KEY=change-me-to-a-random-secret-key
DJANGO_DEBUG=0
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,yourdomain.uz

# PostgreSQL
POSTGRES_DB=confessions_db
POSTGRES_USER=confessions_user
POSTGRES_PASSWORD=change-me-to-a-strong-password
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Docker Hub (for CI/CD)
DOCKERHUB_USERNAME=yourusername
DOCKERHUB_TOKEN=your-token
